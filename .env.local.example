# Copy to .env.local and fill in real values.
# Never commit .env.local.

# === Supabase ===
# From: Supabase Dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-publishable-key
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Used by Drizzle for migrations. Prefer the *session pooler* connection
# string in Supabase (Project Settings → Database → Connection pooling).
# Format: postgresql://postgres.<ref>:<password>@<region>.pooler.supabase.com:5432/postgres
DATABASE_URL=postgresql://postgres:password@host:5432/postgres

# === App ===
# Used by the magic-link / OAuth callback to know where to redirect back to.
# In production set this to your Vercel URL (no trailing slash).
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# === Email (Resend) ===
# Powers transactional booking notifications (PRD 14): new-request alerts to
# property admins, and approve/decline/cancel notices to the requester.
# OPTIONAL — when RESEND_API_KEY is unset the app no-ops (logs and skips) so
# local dev and previews keep working without email.
#   1. Create a key at https://resend.com → API Keys.
#   2. Verify your sending domain (e.g. mathiesonfamily.app) so RESEND_FROM_EMAIL
#      can use it. Until then, Resend's onboarding@resend.dev sender only
#      delivers to the Resend account owner's own address (fine for testing).
# RESEND_API_KEY=
# RESEND_FROM_EMAIL="Mathieson Family <notifications@mathiesonfamily.app>"
