# Copy to .env.local and fill in real values.
# Never commit .env.local.

# === Supabase ===
# From: Supabase Dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-publishable-key
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Used by Drizzle for migrations. Prefer the *session pooler* connection
# string in Supabase (Project Settings → Database → Connection pooling).
# Format: postgresql://postgres.<ref>:<password>@<region>.pooler.supabase.com:5432/postgres
DATABASE_URL=postgresql://postgres:password@host:5432/postgres

# === App ===
# Used by the magic-link / OAuth callback to know where to redirect back to.
# In production set this to your Vercel URL (no trailing slash).
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# === Email (chunk 6 / phase 1) ===
# Resend API key for invitation emails. Optional until chunk 6.
# RESEND_API_KEY=
# RESEND_FROM_EMAIL="Family Portal <noreply@yourdomain.com>"
